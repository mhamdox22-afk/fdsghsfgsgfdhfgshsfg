# 开发环境配置
ENV=production
VITE_APP_ENV=dev

# API
#VITE_APP_BASE_API=https://mobile.antbit.cfd/hApi
# VITE_APP_BASE_API=https://webapi.ciscost.net
VITE_APP_BASE_API=https://webapi2025.moka-vip.com


# STATIC API
VITE_APP_STATIC_API='https://echo-res.oss-cn-hongkong.aliyuncs.com'

# WSS
#VITE_APP_BASE_WSS=wss://webapi.antbit.cfd
# VITE_APP_BASE_WSS=wss://webapi.shopspro.co
VITE_APP_BASE_WSS=wss://webapi.ciscost.net


# 交易所名称
VITE_APP_EXCHANGE_NAME=DEV
# 默认主题 light dark
VITE_APP_PLEATFORM_THEME=light
# 缩写标题
VITE_APP_META_TITLE_SUB=DEV_TITLE_SUB
# 完整标题
VITE_APP_META_TITLE=AntBit.CFD
# 关键字
VITE_APP_META_KEYWORDS=KEYWORDS
# 描述
VITE_APP_META_DESCRIPTION=DESCRIPTION
# # H5 URL
# VITE_APP_PLANFORM_H5=https://ok6.cc
# # PC URL
# VITE_APP_PLANFORM_PC=https://terraustc.xyz

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES=true
