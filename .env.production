# 开发环境配置
ENV=production
VITE_APP_ENV=COINBASE

# API
VITE_APP_BASE_API=https://webapi.coinbaseonline.online

# STATIC API
VITE_APP_STATIC_API='https://tg-mahalebi.oss-cn-hongkong.aliyuncs.com'

# WSS
VITE_APP_BASE_WSS=wss://webapi.coinbaseonline.online

# 交易所名称
VITE_APP_EXCHANGE_NAME=COINBASE
# 默认主题 light dark
VITE_APP_PLEATFORM_THEME=dark
# 缩写标题
VITE_APP_META_TITLE_SUB=COINBASE
# 完整标题
VITE_APP_META_TITLE=COINBASE
# 关键字
VITE_APP_META_KEYWORDS=COINBASE
# 描述
VITE_APP_META_DESCRIPTION=COINBASE
# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES=true
